# ══════════════════════════════════════════════════════════════
# mimi3 (mimo2api) 完整环境变量清单
# 复制为 .env 或在平台环境变量面板中设置（不要提交 .env）
# ══════════════════════════════════════════════════════════════

# ─── 必需 ─────────────────────────────────────────────────────

# Claw 节点连接的 WebSocket 桥接地址（你的公网域名）
# WS_TUNNEL_URL=ws://your-domain.com:8000/ws

# PostgreSQL 数据库连接串（所有本地存储已迁移至此，必需）
# DATABASE_URL=postgresql://user:pass@host:port/dbname?sslmode=require

# ─── 网关配置 ──────────────────────────────────────────────────

# 绑定地址与端口（Leapcell 等平台默认使用 8000）
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8000

# ─── AI API 鉴权（可选，不设置则不对客户端鉴权） ──────────────

# 客户端调用时需要携带的 Bearer 密钥
# MIMO_RELAY_OPENAI_KEY=sk-your-random-secret-here

# ─── WebUI 鉴权（可选，不设置则 WebUI 免登录） ────────────────

# WebUI 登录用户名（默认 admin）
# MIMO_WEBUI_USERNAME=admin

# WebUI 登录密码（不设置则不启用登录）
# MIMO_WEBUI_PASSWORD=change-me

# WebUI 会话签名密钥（不设置时默认用密码参与签名）
# MIMO_WEBUI_SECRET=replace-with-a-long-random-string

# WebUI 会话有效期（秒，默认 43200 = 12 小时）
# MIMO_WEBUI_SESSION_TTL_SECONDS=43200

# 仅在 HTTPS 反代后开启
# MIMO_WEBUI_COOKIE_SECURE=false

# ─── 节点管理（可选） ─────────────────────────────────────────

# 节点 401 后冷却时间（秒，默认 900）
# MIMO_NODE_401_COOLDOWN_SECONDS=900

# ─── 指标存储（可选） ─────────────────────────────────────────

# 历史数据桶大小（秒，默认 1800 = 30 分钟）
# MIMO_METRICS_BUCKET_SECONDS=1800

# 历史数据保留天数（默认 90）
# MIMO_METRICS_RETENTION_DAYS=90

# ─── TTS 语音映射（可选） ─────────────────────────────────────

# 自定义 TTS 语音名映射，JSON 格式
# MIMO_TTS_VOICE_MAP={"alloy":"custom_voice"}
